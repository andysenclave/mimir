{
  "expo": {
    "name": "Mimir",
    "slug": "mimir",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "mimir",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B12"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.thimple.mimir"
    },
    "android": {
      "package": "in.thimple.mimir",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B12"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
